{
  "name": "inspector",
  "publisher": "doublefloat",
  "displayName": "Inspector Gadget",
  "description": "Generic VSCode tool",
  "icon": "images/icon.png",
  "keywords": [],
  "preview": true,
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "doublefloat.inspector.inspectCommands",
        "title": "Inspector Gadget: Inspect VSCode Commands",
        "icon": "$(terminal)"
      },
      {
        "command": "doublefloat.inspector.inspectSettings",
        "title": "Inspector Gadget: Inspect Settings",
        "icon": "$(settings)"
      },
      {
        "command": "doublefloat.inspector.quickPick",
        "title": "Inspector Gadget: QuickPick"
      }
    ],
    "keybindings": [
      {
        "command": "doublefloat.inspector.quickPick",
        "key": "cmd+j cmd+j"
      },
      {
        "command": "doublefloat.inspector.runInTerminal",
        "args": [
          "!!"
        ],
        "key": "cmd+r"
      }
    ],
    "configuration": {
      "title": "Inspector Gadget",
      "properties": {
        "doublefloat.inspector.blame.enabled": {
          "type": "boolean",
          "description": "Enable Git Blame",
          "default": true
        },
        "doublefloat.inspector.blame.placement": {
          "enum": [
            "Inline",
            "StatusBar",
            "CodeLens"
          ],
          "enumDescriptions": [
            "Display as line decoration",
            "Display in the status bar",
            "Display above the current line"
          ],
          "default": "Inline"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
